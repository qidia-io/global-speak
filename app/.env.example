# Environment Variables for Global Translator
# Copy this file to .env and fill in your values

# Hugging Face API Token (required for real translations)
# Get your token from: https://huggingface.co/settings/tokens
HF_TOKEN=

# Model IDs (optional - defaults shown)
HF_SST_MODEL=openai/whisper-large-v3
HF_NMT_MODEL=facebook/nllb-200-distilled-600M
HF_TTS_MODEL=facebook/mms-tts

# Custom Endpoints (optional - for self-hosted models)
# SST_ENDPOINT_URL=
# NMT_ENDPOINT_URL=
# TTS_ENDPOINT_URL=
