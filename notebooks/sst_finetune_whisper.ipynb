   "metadata": {},
   "source": [
    "# 🔊 Fine-Tuning Whisper para SST en Lenguas Low-Resource\n",
    "\n",
    "**Objetivo:** Fine-tunear Whisper (large-v3 o small) para reconocimiento de voz en lenguas\n",
    "con pocos recursos digitales. Este notebook es el proceso documentado detrás de\n",
    "`sainzpaa/whisper-small-wolof-v1`.\n",
    "\n",
    "**Pipeline:** Audio → Whisper Encoder → Whisper Decoder → Transcripción\n",
    "\n",
    "**Requisitos:** Python 3.10+, GPU con ≥8GB VRAM, ~10 horas de audio por lengua."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# === INSTALACIÓN ===\n",
    "# Ejecutar una sola vez\n",
    "!pip install -q \\\n",
    "    datasets>=3.0 \\\n",
    "    transformers>=4.46 \\\n",
    "    accelerate>=1.0 \\\n",
    "    evaluate>=0.4 \\\n",
    "    jiwer>=3.0 \\\n",
    "    librosa>=0.10 \\\n",
    "    soundfile>=0.12 \\\n",
    "    huggingface_hub>=0.24 \\\n",
    "    tensorboard>=2.16"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import os\n",
    "import json\n",
    "import warnings\n",
    "from dataclasses import dataclass, field\n",
    "from typing import Optional\n",
    "\n",
    "import torch\n",
    "import evaluate\n",
    "import librosa\n",
    "import numpy as np\n",
    "from datasets import Dataset, DatasetDict, Audio, load_dataset\n",
    "from transformers import (\n",
    "    WhisperFeatureExtractor,\n",
    "    WhisperTokenizer,\n",
    "    WhisperProcessor,\n",
    "    WhisperForConditionalGeneration,\n",
    "    Seq2SeqTrainingArguments,\n",
    "    Seq2SeqTrainer,\n",
    "    EarlyStoppingCallback,\n",
    ")\n",
    "from huggingface_hub import login as hf_login, HfApi\n",
    "\n",
    "warnings.filterwarnings('ignore')\n",
    "print(f\"PyTorch: {torch.__version__}\")\n",
    "print(f\"CUDA: {torch.cuda.is_available()} | Device: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'CPU'}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# === CONFIGURACIÓN ===\n",
    "# ⚠️ CAMBIAR ESTOS VALORES PARA CADA LENGUA\n",
    "\n",
    "@dataclass\n",
    class Config:\n",
    "    # === Lengua ===\n",
    "    lang_iso: str = \"wo\"            # Código ISO 639-1\n",
    "    lang_name: str = \"Wolof\"        # Nombre nativo\n",
    "    lang_common_voice: str = \"wo\"   # Código en Common Voice\n",
    "    whisper_lang: str = \"wolof\"     # Nombre Whisper\n",
    "    \n",
    "    # === Modelo base ===\n",
    "    base_model: str = \"openai/whisper-small\"  # small, medium, large-v3\n",
    "    \n",
    "    # === Datos ===\n",
    "    use_common_voice: bool = True\n",
    "    use_custom_data: bool = True\n",
    "    custom_data_path: str = \"\"  # Ruta a audios propios\n",
    "    \n",
    "    # === Entrenamiento ===\n",
    "    output_dir: str = f\"./whisper-{lang_iso}-finetune\"\n",
    "    num_train_epochs: int = 10\n",
    "    per_device_batch_size: int = 16  # Reducir si OOM\n",
    "    gradient_accumulation_steps: int = 1\n",
    "    learning_rate: float = 1e-5\n",
    "    warmup_steps: int = 500\n",
    "    max_steps: int = 4000  # -1 para usar epochs\n",
    "    eval_steps: int = 500\n",
    "    save_steps: int = 1000\n",
    "    logging_steps: int = 100\n",
    "    \n",
    "    # === HF Hub ===\n",
    "    push_to_hub: bool = True\n",
    "    hub_model_id: str = f\"sainzpaa/whisper-{lang_iso}-{base_model.split('/')[1]}\"\n",
    "    \n",
    "    # === Audio ===\n",
    "    sampling_rate: int = 16000\n",
    "    max_duration: float = 30.0  # segundos máx\n",
    "    \n",
    "cfg = Config()\n",
    "print(f\"Lengua: {cfg.lang_name} ({cfg.lang_iso})\")\n",
    "print(f\"Modelo base: {cfg.base_model}\")\n",
    "print(f\"Output: {cfg.output_dir}\")\n",
    "print(f\"HF Hub: {cfg.hub_model_id}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 1. Cargar Datos\n",
    "\n",
    "Soporta dos fuentes:\n",
    "1. **Common Voice** — Dataset multilingüe de Mozilla\n",
    "2. **Datos propios** — Audios WAV + transcripciones en CSV\n",
    "\n",
    "Para Wolof, Common Voice tiene ~15 horas. Para Fula/Bambara puede que no haya."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_common_voice(lang_code: str, trust_remote: bool = True) -> DatasetDict:\n",
    "    \"\"\"Carga dataset Common Voice para una lengua.\"\"\"\n",
    "    print(f\"Cargando Common Voice: {lang_code}...\")\n",
    "    try:\n",
    "        dataset = load_dataset(\n",
    "            \"mozilla-foundation/common_voice_17_0\",\n",
    "            lang_code,\n",
    "            trust_remote_code=trust_remote,\n",
    "            split=[\"train\", \"validation\", \"test\"],\n",
    "        )\n",
    "        print(f\"  Train: {len(dataset[0]):,} | Val: {len(dataset[1]):,} | Test: {len(dataset[2]):,}\")\n",
    "        return DatasetDict({\n",
    "            \"train\": dataset[0],\n",
    "            \"validation\": dataset[1],\n",
    "            \"test\": dataset[2],\n",
    "        })\n",
    "    except Exception as e:\n",
    "        print(f\"  ⚠️ No disponible: {e}\")\n",
    "        print(f\"  → Prueba con: common_voice_13_0 o common_voice_11_0\")\n",
    "        return None\n",
    "\n",
    "def load_custom_data(path: str) -> DatasetDict:\n",
    "    \"\"\"Carga datos propios: carpeta con audios WAV + metadata.csv\n",
    "    \n",
    "    metadata.csv debe tener columnas: path, sentence\n",
    "    \"\"\"\n",
    "    if not path or not os.path.exists(path):\n",
    "        return None\n",
    "    \n",
    "    csv_path = os.path.join(path, \"metadata.csv\")\n",
    "    if not os.path.exists(csv_path):\n",
    "        print(f\"  ⚠️ No se encontró {csv_path}\")\n",
    "        return None\n",
    "    \n",
    "    dataset = load_dataset(\n",
    "        \"audiofolder\",\n",
    "        data_dir=path,\n",
    "        data_files={\"train\": csv_path},\n",
    "        split=\"train\",\n",
    "    )\n",
    "    print(f\"  Datos propios: {len(dataset):,} samples\")\n",
    "    return DatasetDict({\"train\": dataset, \"validation\": None, \"test\": None})\n",
    "\n",
    "# --- CARGAR ---\n",
    "dataset = load_common_voice(cfg.lang_common_voice)\n",
    "custom = load_custom_data(cfg.custom_data_path)\n",
    "\n",
    "# Combinar datasets si hay datos propios\n",
    "if dataset is None and custom is None:\n",
    "    raise RuntimeError(\"No hay datos disponibles. Sube audios propios o elige otra lengua.\")\n",
    "elif custom is not None:\n",
    "    # Merge custom data into train set\n",
    "    if dataset is None:\n",
    "        dataset = custom\n",
    "    else:\n",
    "        dataset[\"train\"] = dataset[\"train\"].concatenate(custom[\"train\"])"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 2. Preprocesamiento de Audio\n",
    "\n",
    "1. Remuestrear a 16kHz\n",
    "2. Filtrar audios muy largos (>30s) o muy cortos (<0.5s)\n",
    "3. Extraer características mel-espectrograma"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Cargar processor (feature_extractor + tokenizer)\n",
    "feature_extractor = WhisperFeatureExtractor.from_pretrained(cfg.base_model)\n",
    "tokenizer = WhisperTokenizer.from_pretrained(\n",
    "    cfg.base_model,\n",
    "    language=cfg.whisper_lang,\n",
    "    task=\"transcribe\",\n",
    ")\n",
    "processor = WhisperProcessor.from_pretrained(cfg.base_model)\n",
    "\n",
    "# Filtrar audios por duración\n",
    "def is_audio_length_in_range(batch: dict) -> bool:\n",
    "    \"\"\"Filtra audios que duran entre 0.5s y max_duration.\"\"\"\n",
    "    audio = batch[\"audio\"]\n",
    "    duration = len(audio[\"array\"]) / audio[\"sampling_rate\"]\n",
    "    return 0.5 <= duration <= cfg.max_duration\n",
    "\n",
    "dataset_filtered = dataset.filter(is_audio_length_in_range)\n",
    "print(f\"Dataset filtrado:\")\n",
    "for split in dataset_filtered:\n",
    "    if dataset_filtered[split] is not None:\n",
    "        original = len(dataset[split]) if dataset[split] is not None else 0\n",
    "        filtered = len(dataset_filtered[split]) if dataset_filtered[split] is not None else 0\n",
    "        print(f\"  {split}: {original} → {filtered}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def prepare_dataset(batch: dict) -> dict:\n",
    "    \"\"\"Prepara: input_features (mel) + labels (tokens).\"\"\"\n",
    "    \n",
    "    # Cargar y remuestrear audio a 16kHz\n",
    "    audio = batch[\"audio\"]\n",
    "    \n",
    "    # Compute mel spectrogram features\n",
    "    batch[\"input_features\"] = feature_extractor(\n",
    "        audio[\"array\"],\n",
    "        sampling_rate=audio[\"sampling_rate\"],\n",
    "    ).input_features[0]\n",
    "    \n",
    "    # Tokenizar transcripción\n",
    "    batch[\"labels\"] = tokenizer(batch[\"sentence\"]).input_ids\n",
    "    return batch\n",
    "\n",
    "# Aplicar preprocesamiento\n",
    "dataset_prepared = dataset_filtered.map(\n",
    "    prepare_dataset,\n",
    "    remove_columns=dataset_filtered[\"train\"].column_names,\n",
    "    num_proc=2,\n",
    "    desc=\"Preprocesando audios...\",\n",
    ")\n",
    "print(\"✅ Dataset preparado\")\n",
    "print(f\"Train: {len(dataset_prepared['train']):,} samples\")\n",
    "if dataset_prepared.get('validation'):\n",
    "    print(f\"Val:   {len(dataset_prepared['validation']):,} samples\")\n",
    "if dataset_prepared.get('test'):\n",
    "    print(f\"Test:  {len(dataset_prepared['test']):,} samples\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 3. Data Collator\n",
    "\n",
    "Maneja el padding dinámico para lotes de audios de distinta duración."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "@dataclass\n",
    "class DataCollatorSpeechSeq2SeqWithPadding:\n",
    "    \"\"\"Data collator con padding dinámico.\"\"\"\n",
    "    processor: object\n",
    "    decoder_start_token_id: int\n",
    "    \n",
    "    def __call__(self, features: list[dict]) -> dict:\n",
    "        # Dividir inputs y labels\n",
    "        input_features = [{\"input_features\": f[\"input_features\"]} for f in features]\n",
    "        label_features = [{\"input_ids\": f[\"labels\"]} for f in features]\n",
    "        \n",
    "        # Padding de inputs\n",
    "        batch = self.processor.feature_extractor.pad(\n",
    "            input_features, return_tensors=\"pt\"\n",
    "        )\n",
    "        \n",
    "        # Padding de labels\n",
    "        labels_batch = self.processor.tokenizer.pad(\n",
    "            label_features, return_tensors=\"pt\"\n",
    "        )\n",
    "        \n",
    "        # Reemplazar padding con -100 (ignorados en loss)\n",
    "        labels = labels_batch[\"input_ids\"].masked_fill(\n",
    "            labels_batch.attention_mask.ne(1), -100\n",
    "        )\n",
    "        \n",
    "        batch[\"labels\"] = labels\n",
    "        \n",
    "        # Forzar decoder_start_token_id si no está\n",
    "        if (labels[:, 0] != self.decoder_start_token_id).all():\n",
    "            batch[\"labels\"] = torch.cat([\n",
    "                torch.full((labels.shape[0], 1), self.decoder_start_token_id),\n",
    "                labels,\n",
    "            ], dim=1)\n",
    "        \n",
    "        return batch\n",
    "\n",
    "data_collator = DataCollatorSpeechSeq2SeqWithPadding(\n",
    "    processor=processor,\n",
    "    decoder_start_token_id=model.config.decoder_start_token_id,\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 4. Cargar Modelo Base\n",
    "\n",
    "Cargamos Whisper pre-entrenado con soporte para la lengua objetivo.\n",
    "Si la lengua está en Whisper (99 lenguas), usamos el tokenizer con `language=`.\n",
    "Si no está, forzamos el fine-tuning desde cero."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n",
    "torch_dtype = torch.float16 if device == \"cuda\" else torch.float32\n",
    "\n",
    "model = WhisperForConditionalGeneration.from_pretrained(\n",
    "    cfg.base_model,\n",
    "    torch_dtype=torch_dtype,\n",
    "    use_cache=False,\n",
    ")\n",
    "\n",
    "# Forzar idioma y tarea (importante para lenguas no soportadas nativamente)\n",
    "model.config.forced_decoder_ids = None  # Dejar que aprenda\n",
    "model.config.suppress_tokens = []  # No suprimir tokens\n",
    "\n",
    "model.to(device)\n",
    "print(f\"Modelo cargado: {cfg.base_model}\")\n",
    "print(f\"Parámetros: {model.num_parameters():,}\")\n",
    "print(f\"Device: {device}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 5. Métrica de Evaluación\n",
    "\n",
    "Word Error Rate (WER) y Character Error Rate (CER)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "wer_metric = evaluate.load(\"wer\")\n",
    "cer_metric = evaluate.load(\"cer\")\n",
    "\n",
    "def compute_metrics(pred) -> dict:\n",
    "    pred_ids = pred.predictions\n",
    "    label_ids = pred.label_ids\n",
    "    \n",
    "    # Reemplazar -100 con pad_token_id\n",
    "    label_ids[label_ids == -100] = tokenizer.pad_token_id\n",
    "    \n",
    "    # Decodificar\n",
    "    pred_str = tokenizer.batch_decode(pred_ids, skip_special_tokens=True)\n",
    "    label_str = tokenizer.batch_decode(label_ids, skip_special_tokens=True)\n",
    "    \n",
    "    # Normalizar: lowercase + strip\n",
    "    pred_str = [p.strip().lower() for p in pred_str]\n",
    "    label_str = [l.strip().lower() for l in label_str]\n",
    "    \n",
    "    wer = wer_metric.compute(predictions=pred_str, references=label_str)\n",
    "    cer = cer_metric.compute(predictions=pred_str, references=label_str)\n",
    "    \n",
    "    return {\"wer\": round(wer, 4), \"cer\": round(cer, 4)}\n",
    "\n",
    "print(\"✅ Métricas cargadas: WER + CER\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 6. Entrenamiento\n",
    "\n",
    "Fine-tuning con Seq2SeqTrainer de HuggingFace."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "training_args = Seq2SeqTrainingArguments(\n",
    "    output_dir=cfg.output_dir,\n",
    "    per_device_train_batch_size=cfg.per_device_batch_size,\n",
    "    gradient_accumulation_steps=cfg.gradient_accumulation_steps,\n",
    "    learning_rate=cfg.learning_rate,\n",
    "    warmup_steps=cfg.warmup_steps,\n",
    "    max_steps=cfg.max_steps,\n",
    "    num_train_epochs=cfg.num_train_epochs,\n",
    "    \n",
    "    evaluation_strategy=\"steps\",\n",
    "    eval_steps=cfg.eval_steps,\n",
    "    save_strategy=\"steps\",\n",
    "    save_steps=cfg.save_steps,\n",
    "    logging_steps=cfg.logging_steps,\n",
    "    \n",
    "    predict_with_generate=True,\n",
    "    generation_max_length=225,\n",
    "    \n",
    "    fp16=device == \"cuda\",\n",
    "    dataloader_num_workers=2,\n",
    "    \n",
    "    load_best_model_at_end=True,\n",
    "    metric_for_best_model=\"wer\",\n",
    "    greater_is_better=False,\n",
    "    \n",
    "    push_to_hub=cfg.push_to_hub,\n",
    "    hub_model_id=cfg.hub_model_id,\n",
    "    hub_strategy=\"every_save\",\n",
    "    \n",
    "    report_to=[\"tensorboard\"],\n",
    "    remove_unused_columns=False,\n",
    "    \n",
    "    gradient_checkpointing=True,\n",
    "    optim=\"adamw_torch_fused\",\n",
    "    \n",
    "    dataloader_pin_memory=True,\n",
    "    \n",
    "    # Early stopping\n",
    "    metric_for_best_model=\"wer\",\n",
    "    greater_is_better=False,\n",
    "    load_best_model_at_end=True,\n",
    ")\n",
    "\n",
    "trainer = Seq2SeqTrainer(\n",
    "    model=model,\n",
    "    args=training_args,\n",
    "    train_dataset=dataset_prepared[\"train\"],\n",
    "    eval_dataset=dataset_prepared.get(\"validation\"),\n",
    "    data_collator=data_collator,\n",
    "    compute_metrics=compute_metrics,\n",
    "    tokenizer=processor.feature_extractor,\n",
    "    callbacks=[EarlyStoppingCallback(early_stopping_patience=3)],\n",
    ")\n",
    "\n",
    "print(\"🏋️ Trainer configurado. Listo para entrenar.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# === INICIAR ENTRENAMIENTO ===\n",
    "# ⚠️ Esto puede tomar horas dependiendo de la GPU y datos\n",
    "\n",
    "print(\"🚀 Iniciando fine-tuning...\")\n",
    "if cfg.do_train and torch.cuda.is_available():\n",
    "    trainer.train()\n",
    "    \n",
    "    # Guardar y subir a HF Hub\n",
    "    trainer.save_model()\n",
    "    if cfg.push_to_hub:\n",
    "        print(f\"📤 Subiendo a: {cfg.hub_model_id}\")\n",
    "        trainer.push_to_hub()\n",
    "else:\n",
    "    print(\"⚠️ Entrenamiento desactivado o sin GPU.\")\n",
    "    print(\"→ Configura cfg.do_train=True y asegura CUDA disponible.\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## 7. Evaluación Final\n",
    "\n",
    "Mide WER/CER en el set de test."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def evaluate_model(model, dataset_split, split_name=\"test\"):\n",
    "    \"\"\"Evalúa el modelo en un split.\"\"\"\n",
    "    model.eval()\n",
    "    predictions = []\n",
    "    references = []\n",
    "    \n",
    "    for batch in dataset_split.iter(batch_size=32):\n",
    "        with torch.no_grad():\n",
    "            input_features = torch.tensor(batch[\"input_features\"]).to(device)\n",
    "            generated_ids = model.generate(\n",
    "                input_features,\n",
    "                language=cfg.whisper_lang,\n",
    "                task=\"transcribe\",\n",
    "            )\n",
    "        \n",
    "        pred_text = tokenizer.batch_decode(generated_ids, skip_special_tokens=True)\n",
    "        ref_text = tokenizer.batch_decode(\n",
    "            [l for l in batch[\"labels\"] if l != -100],\n",
    "            skip_special_tokens=True,\n",
    "        )\n",
    "        \n",
    "        predictions.extend([p.strip().lower() for p in pred_text])\n",
    "        references.extend([r.strip().lower() for r in ref_text])\n",
    "    \n",
    "    wer = wer_metric.compute(predictions=predictions, references=references)\n",
    "    cer = cer_metric.compute(predictions=predictions, references=references)\n",
    "    \n",
    "    print(f\"📊 {split_name.upper()}: WER={wer:.4f} | CER={cer:.4f}\")\n",
    "    print(f\"   Samples evaluados: {len(predictions)}\")\n",
    "    \n",
    "    # Mostrar ejemplos\n",
    "    print(\"\\n📝 Ejemplos:\")\n",
    "    for i in range(min(5, len(predictions))):\n",
    "        print(f\"  REF: {references[i]}\")\n",
    "        print(f\"  PRED: {predictions[i]}\")\n",
    "        print()\n",
    "    \n",
    "    return {\"wer\": wer, \"cer\": cer}\n",
    "\n",
    "results = {}\n",
    "for split in [\"test\", \"validation\"]:\n",
    "    if dataset_prepared.get(split) and len(dataset_prepared[split]) > 0:\n",
    "        results[split] = evaluate_model(model, dataset_prepared[split], split)\n",
    "\n",
